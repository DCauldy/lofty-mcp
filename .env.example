# ─── Local stdio mode (required) ───
LOFTY_API_KEY=your-api-key-here

# ─── Hosted mode (Vercel deployment) ───
SERVER_URL=https://your-app.vercel.app
ENCRYPTION_KEY=your-64-char-hex-string-here

# Vercel KV (from Vercel KV dashboard)
KV_REST_API_URL=https://your-kv-instance.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token-here

# ─── Lofty OAuth ("Sign in with Lofty") ───
# Optional: enables OAuth sign-in alongside API key auth
LOFTY_OAUTH_CLIENT_ID=your-lofty-oauth-client-id
LOFTY_OAUTH_CLIENT_SECRET=your-lofty-oauth-client-secret
